generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStatus {
  IN_STOCK
  OUT_OF_STOCK
  COMING_SOON
}

enum AdminRole {
  ADMIN
  EDITOR
}

enum BannerPlacement {
  HOME_HERO
  PRODUCTS_HERO
  ABOUT_HERO
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         AdminRole @default(EDITOR)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  @@map("admin_users")
}

model ProductLine {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  imageUrl    String?
  benefits    Json?
  isFeatured  Boolean   @default(false)
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isFeatured, isActive, sortOrder])
  @@index([isActive, sortOrder])
  @@map("product_lines")
}

model ProductCategory {
  id          String            @id @default(cuid())
  parentId    String?
  slug        String            @unique
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  parent      ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children    ProductCategory[] @relation("ProductCategoryTree")
  products    Product[]

  @@index([parentId])
  @@index([isActive, sortOrder])
  @@map("product_categories")
}

model Brand {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  logoUrl     String?
  websiteUrl  String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive, sortOrder])
  @@map("brands")
}

model Product {
  id                 String              @id @default(cuid())
  lineId             String
  categoryId         String?
  brandId            String?
  slug               String              @unique
  name               String
  size               String?
  excerpt            String
  description        String
  ingredients        String?
  benefits           Json?
  skinTypes          Json?
  concerns           Json?
  routineStep        String?
  howToUse           String?
  warnings           String?
  featured           Boolean             @default(false)
  status             ProductStatus       @default(IN_STOCK)
  sortOrder          Int                 @default(0)
  seoTitle           String?
  seoDescription     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  publishedAt        DateTime?
  line               ProductLine         @relation(fields: [lineId], references: [id], onDelete: Restrict)
  category           ProductCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand              Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  images             ProductImage[]
  variants           ProductVariant[]
  productIngredients ProductIngredient[]
  usageSteps         ProductUsageStep[]

  @@index([lineId])
  @@index([categoryId])
  @@index([brandId])
  @@index([status, sortOrder])
  @@map("products")
}

model ProductVariant {
  id             String   @id @default(cuid())
  productId      String
  sku            String?  @unique
  name           String
  size           String?
  price          Decimal? @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2)
  stockQuantity  Int      @default(0)
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isActive, sortOrder])
  @@map("product_variants")
}

model Ingredient {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String?
  origin      String?
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  products    ProductIngredient[]

  @@index([isActive])
  @@map("ingredients")
}

model ProductIngredient {
  id           String     @id @default(cuid())
  productId    String
  ingredientId String
  benefit      String?
  sortOrder    Int        @default(0)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@unique([productId, ingredientId])
  @@index([productId])
  @@index([ingredientId])
  @@map("product_ingredients")
}

model ProductUsageStep {
  id          String  @id @default(cuid())
  productId   String
  title       String
  description String
  sortOrder   Int     @default(0)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_usage_steps")
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  storagePath String?
  publicUrl   String
  alt         String?
  caption     String?
  sortOrder   Int      @default(0)
  isCover     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Banner {
  id        String          @id @default(cuid())
  placement BannerPlacement
  title     String
  subtitle  String?
  imageUrl  String
  ctaLabel  String?
  ctaHref   String?
  isActive  Boolean         @default(true)
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([placement, isActive, sortOrder])
  @@map("banners")
}
